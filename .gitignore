# ESPHome build + secrets
/.esphome/
/secrets.yaml

# Python caches from local external components
__pycache__/
*.pyc

# Compiled firmware images contain baked-in Wi-Fi/OTA credentials.
# Keep them local; rebuild with `python -m esphome compile`.
*.bin

# Generated by tools/build.py
/generated.build.yaml

# PyInstaller widget build artifacts (keep the .spec + build scripts, drop output)
/client/dist/
/client/build/smalltv_widget/
*.manifest


# Copy this file to `secrets.yaml` and fill in real values.
# secrets.yaml is git-ignored so credentials never get committed.

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Password required to push OTA updates to the device.
ota_password: "CHOOSE_AN_OTA_PASSWORD"

# Password for the device's own fallback hotspot (shown if Wi-Fi fails).
ap_password: "CHOOSE_AN_AP_PASSWORD"
